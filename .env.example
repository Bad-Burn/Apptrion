# Apptrion Backend Configuration
# This file stores sensitive information - DO NOT commit to version control

# Server Configuration
PORT=3000

# Email Configuration (Optional - for Gmail SMTP)
# To enable email sending, uncomment and fill in your credentials:
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-specific-password

# Receiving Email (where contact form submissions are sent)
# If not set, emails will be sent to the sender's email address
# CONTACT_EMAIL=contact@apptrion.com

# Note: If using Gmail, you need to:
# 1. Enable 2-Step Verification on your Google Account
# 2. Generate an App-Specific Password
# 3. Use that password in EMAIL_PASS (not your regular Gmail password)
